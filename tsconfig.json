{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "nestgram": ["lib"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "downlevelIteration": true
  },
  // Without bounds, `tsc -p tsconfig.json` also compiles `website/` and
  // `examples/` — separate workspaces with their own tsconfig, deps and build.
  // `website/` alone makes `npm run typecheck` permanently fail on Astro's
  // virtual `astro:content` module, which only Astro's own config can resolve,
  // and a check that can never pass is a check nobody reads.
  "exclude": ["node_modules", "dist", "website", "examples"]
}
