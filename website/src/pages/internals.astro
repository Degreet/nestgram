---
import logo from '../assets/nestgram.svg';

const docsUrl = '/01-quickstart';
const githubUrl = 'https://github.com/Degreet/nestgram-v2';

// Code samples live here as pre-tokenised HTML strings and are injected with
// set:html — Astro parses `{` in the template as an expression, so literal
// braces in code can't sit inline. Same pattern the landing page uses.
const dispatcherCode = `<span class="k">const</span> ctx = <span class="k">this</span>.contextFactory.<span class="f">wrap</span>(update);        <span class="c">// 3 — wrap, no mutation</span>
<span class="k">if</span> (!ctx) <span class="k">return</span>;

<span class="k">const</span> [route] = <span class="k">await this</span>.routeMatcher.<span class="f">findMatches</span>(table, ctx); <span class="c">// 4 — match</span>
<span class="k">if</span> (!route) <span class="k">return</span>;

<span class="k">const</span> result = <span class="k">await this</span>.<span class="f">invokerFor</span>(route)(ctx);   <span class="c">// 5 — Nest pipeline</span>
<span class="k">await this</span>.resultHandler.<span class="f">handle</span>(result, ctx);     <span class="c">// 6 — reply</span>`;

const executorCode = `<span class="k">const</span> invoker = <span class="k">this</span>.ecc.<span class="f">create</span>(
  instance, callback, methodName,
  <span class="t">ROUTE_ARGS_METADATA</span>,
  <span class="k">this</span>.paramsFactory,   <span class="c">// ⚠ REQUIRED — without it ECC resolves no params</span>
  undefined, undefined, undefined,
  <span class="t">NESTGRAM_CONTEXT_TYPE</span>, <span class="c">// 'telegram' — visible via ctx.getType()</span>
);
<span class="k">return</span> (ctx) => <span class="f">invoker</span>(ctx.event, ctx); <span class="c">// event = args[0], ctx = args[1]</span>`;

const resultCode = `<span class="s">'hello'</span>              <span class="c">// string  → event.answer('hello')</span>
<span class="k">new</span> <span class="t">SendPhoto</span>(...)   <span class="c">// command → .fetch() (execute)</span>
undefined / void       <span class="c">// do nothing (noop)</span>`;

const greetCode = `<span class="k">import</span> { Router, Command, OnMessage, Message } <span class="k">from</span> <span class="s">'nestgram'</span>;

<span class="d2">@Router</span>()
<span class="k">export class</span> <span class="t">GreetRouter</span> {
  <span class="d2">@Command</span>(<span class="s">'start'</span>)
  <span class="f">start</span>(message: <span class="t">Message</span>) {              <span class="c">// typed positional event, zero decorators</span>
    <span class="k">return</span> <span class="s">\`Hello, \${message.from.first_name}!\`</span>; <span class="c">// string → reply</span>
  }

  <span class="d2">@OnMessage</span>()
  <span class="f">echo</span>(message: <span class="t">Message</span>) {
    <span class="k">return</span> message.text;
  }
}`;
---

<!doctype html>
<html lang="en" data-theme="dark">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Nestgram · Internals — how the engine works</title>
<meta name="description" content="A deep dive into how Nestgram works under the hood: the update → dispatch pipeline, the lib/ layout, and the decisions behind the framework." />
<meta name="robots" content="noindex" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Hanken+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap');

  :root {
    --bg: #07090d;
    --bg-2: #0b0e14;
    --panel: #0f131b;
    --panel-2: #141925;
    --border: rgba(255, 255, 255, 0.07);
    --border-strong: rgba(255, 255, 255, 0.13);
    --text: #eef1f6;
    --text-2: #b7c0cf;
    --faint: #525c6e;
    --a1: #36b4f4;       /* light blue */
    --a2: #1f8fe6;       /* core blue  */
    --accent-soft: rgba(54, 180, 244, 0.13);
    --amber: #ffcb7a;
    --green: #5fd39a;
    --pink: #f48fb1;
    --radius: 14px;
    --radius-lg: 20px;
    --maxw: 1120px;
    --font: 'Hanken Grotesk', system-ui, sans-serif;
    --font-display: 'Space Grotesk', 'Hanken Grotesk', system-ui, sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: var(--font);
    color: var(--text);
    background:
      radial-gradient(1200px 600px at 78% -8%, rgba(54, 180, 244, 0.12), transparent 60%),
      radial-gradient(900px 500px at 0% 0%, rgba(31, 143, 230, 0.08), transparent 55%),
      var(--bg);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  a { color: var(--a1); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }

  /* ---------- top nav ---------- */
  .nav {
    position: sticky; top: 0; z-index: 50;
    backdrop-filter: blur(14px);
    background: color-mix(in oklab, var(--bg) 80%, transparent);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    max-width: var(--maxw); margin: 0 auto; padding: 13px 24px;
    display: flex; align-items: center; gap: 18px;
  }
  .brand { display: flex; align-items: center; gap: 10px; font-weight: 600; font-family: var(--font-display); letter-spacing: -0.2px; color: var(--text); }
  .brand img { width: 26px; height: 26px; display: block; }
  .brand .sub { font-family: var(--mono); font-size: 11px; color: var(--a1); background: var(--accent-soft); border: 1px solid rgba(54,180,244,0.25); padding: 2px 7px; border-radius: 6px; font-weight: 500; }
  .nav-links { margin-left: auto; display: flex; gap: 22px; font-size: 14px; align-items: center; }
  .nav-links a { color: var(--text-2); }
  .nav-links a:hover { color: var(--text); text-decoration: none; }
  .nav-links a.ext { color: var(--faint); }
  @media (max-width: 820px) { .nav-links a:not(.ext) { display: none; } }

  /* ---------- hero ---------- */
  .hero { padding: 70px 0 38px; }
  .eyebrow {
    display: inline-flex; align-items: center; gap: 9px;
    font-family: var(--mono); font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--a1); background: var(--accent-soft);
    border: 1px solid rgba(54, 180, 244, 0.24); padding: 6px 13px; border-radius: 999px;
  }
  .dot-pulse { width: 7px; height: 7px; border-radius: 50%; background: var(--a1); box-shadow: 0 0 0 0 rgba(54,180,244,0.6); animation: pulse 2.2s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(54,180,244,0.5); } 70% { box-shadow: 0 0 0 8px rgba(54,180,244,0); } 100% { box-shadow: 0 0 0 0 rgba(54,180,244,0); } }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(34px, 6vw, 56px); line-height: 1.06; margin: 22px 0 16px;
    letter-spacing: -1.3px; font-weight: 700;
  }
  h1 .grad { background: linear-gradient(110deg, var(--a1) 10%, var(--a2)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .lead { font-size: clamp(16px, 2.3vw, 20px); color: var(--text-2); max-width: 760px; }
  .lead strong { color: var(--text); font-weight: 600; }

  .signoff {
    margin-top: 24px; display: flex; align-items: center; gap: 14px;
    color: var(--faint); font-size: 14px; max-width: 720px;
  }
  .signoff .avatar {
    width: 40px; height: 40px; flex: none; border-radius: 11px;
    background: linear-gradient(140deg, #1a2740, #0f131b); border: 1px solid var(--border-strong);
    display: grid; place-items: center; font-size: 18px;
  }

  /* ---------- mental model ---------- */
  .mental {
    margin: 42px 0 8px;
    background: linear-gradient(180deg, var(--panel-2), var(--panel));
    border: 1px solid var(--border); border-radius: var(--radius-lg);
    padding: 26px 28px;
  }
  .mm-label { font-family: var(--mono); font-size: 11px; letter-spacing: 2px; color: var(--faint); text-transform: uppercase; margin-bottom: 16px; }
  .mm-flow { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; }
  .mm-box {
    font-family: var(--mono); font-size: 14px; padding: 10px 15px;
    background: var(--bg); border: 1px solid var(--border-strong); border-radius: 11px; white-space: nowrap;
  }
  .mm-accent { background: var(--accent-soft); border-color: rgba(54,180,244,0.42); color: var(--a1); }
  .mm-arrow { color: var(--faint); font-family: var(--mono); }

  /* ---------- sections ---------- */
  section { padding: 56px 0; border-top: 1px solid var(--border); }
  .sec-tag { font-family: var(--mono); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--a1); }
  h2 { font-family: var(--font-display); font-size: clamp(26px, 4vw, 34px); margin: 12px 0 14px; letter-spacing: -0.7px; font-weight: 700; }
  .sec-intro { color: var(--text-2); max-width: 770px; font-size: 17px; }

  /* ---------- cards grid ---------- */
  .grid { display: grid; gap: 16px; margin-top: 30px; }
  .grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
  @media (max-width: 860px) { .grid.cols-3 { grid-template-columns: 1fr; } }

  .card {
    background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 22px; transition: border-color .18s ease, transform .18s ease, background .18s ease;
  }
  .card:hover { border-color: var(--border-strong); transform: translateY(-2px); background: var(--panel-2); }
  .card h3 { margin: 0 0 8px; font-size: 17px; font-family: var(--font-display); display: flex; align-items: center; gap: 10px; }
  .card h3 .ic { font-size: 19px; }
  .card p { margin: 0; color: var(--text-2); font-size: 14.5px; }
  .card .path { font-family: var(--mono); font-size: 12px; color: var(--faint); margin-top: 12px; display: block; }

  /* pain vs gain */
  .vs { display: grid; grid-template-columns: 1fr 1fr; gap: 0; margin-top: 30px; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  @media (max-width: 760px) { .vs { grid-template-columns: 1fr; } }
  .vs-col { padding: 24px; }
  .vs-col.pain { background: rgba(244, 143, 177, 0.04); border-right: 1px solid var(--border); }
  .vs-col.gain { background: rgba(95, 211, 154, 0.045); }
  @media (max-width: 760px) { .vs-col.pain { border-right: none; border-bottom: 1px solid var(--border); } }
  .vs-col h4 { margin: 0 0 16px; font-family: var(--mono); font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; }
  .vs-col.pain h4 { color: var(--pink); }
  .vs-col.gain h4 { color: var(--green); }
  .vs-col ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 13px; }
  .vs-col li { font-size: 14.5px; color: var(--text-2); padding-left: 26px; position: relative; }
  .vs-col li b { color: var(--text); font-weight: 600; }
  .vs-col.pain li::before { content: "✕"; position: absolute; left: 0; color: var(--pink); }
  .vs-col.gain li::before { content: "✓"; position: absolute; left: 0; color: var(--green); }

  /* ---------- pipeline steps ---------- */
  .steps { margin-top: 36px; position: relative; }
  .step { display: grid; grid-template-columns: 56px 1fr; gap: 22px; padding-bottom: 14px; }
  .step-rail { display: flex; flex-direction: column; align-items: center; }
  .step-n {
    width: 46px; height: 46px; flex: none; border-radius: 13px;
    display: grid; place-items: center; font-family: var(--mono); font-weight: 700; font-size: 17px;
    background: linear-gradient(150deg, var(--panel-2), var(--panel)); border: 1px solid var(--border-strong);
    color: var(--a1); box-shadow: 0 0 0 4px rgba(54,180,244,0.06);
  }
  .step-line { width: 2px; flex: 1; margin: 8px 0; background: linear-gradient(var(--border-strong), transparent); }
  .step:last-child .step-line { display: none; }
  .step-body { padding-bottom: 26px; min-width: 0; }
  .step-body h3 { margin: 8px 0 6px; font-size: 19px; font-family: var(--font-display); display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px; }
  .step-body .where { font-family: var(--mono); font-size: 12px; color: var(--a1); background: var(--accent-soft); border: 1px solid rgba(54,180,244,0.2); padding: 3px 9px; border-radius: 7px; }
  .step-body p { margin: 0 0 10px; color: var(--text-2); font-size: 15px; }
  .step-body p code, .inline-code { font-family: var(--mono); font-size: 0.88em; background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 1px 6px; border-radius: 6px; color: #cdd6e6; }
  .step-key { font-size: 13.5px; color: var(--faint); border-left: 2px solid var(--a1); padding: 4px 0 4px 13px; margin-top: 12px; }
  .step-key b { color: var(--text-2); }

  /* ---------- flow diagram ---------- */
  .diagram {
    margin: 32px auto 8px; max-width: 600px;
    display: flex; flex-direction: column; align-items: stretch;
  }
  .dstage {
    display: flex; align-items: center; gap: 14px;
    background: linear-gradient(180deg, var(--panel-2), var(--panel));
    border: 1px solid var(--border-strong); border-radius: 13px;
    padding: 14px 16px; position: relative;
  }
  .dstage .dnum {
    width: 30px; height: 30px; flex: none; border-radius: 9px;
    display: grid; place-items: center; font-family: var(--mono); font-weight: 700; font-size: 14px;
    background: var(--accent-soft); color: var(--a1); border: 1px solid rgba(54,180,244,0.32);
  }
  .dstage .dtxt { flex: 1; min-width: 0; }
  .dstage .dtxt b { font-size: 15px; font-family: var(--font-display); }
  .dstage .dtxt small { display: block; color: var(--text-2); font-size: 12.5px; line-height: 1.45; }
  .dstage .dpath { font-family: var(--mono); font-size: 11px; color: var(--faint); white-space: nowrap; }
  @media (max-width: 560px) { .dstage .dpath { display: none; } }

  .dstage.edge {
    background: var(--accent-soft); border-color: rgba(54,180,244,0.28);
    justify-content: center; text-align: center; font-family: var(--mono); font-size: 13px; color: var(--a1);
  }
  .dstage.edge .ic { margin-right: 8px; }
  .dstage.hot { border-color: rgba(54,180,244,0.5); box-shadow: 0 0 0 4px rgba(54,180,244,0.07); }

  .dconn { height: 26px; width: 2px; align-self: center; background: linear-gradient(var(--a1), rgba(54,180,244,0.25)); position: relative; }
  .dconn::after {
    content: ""; position: absolute; bottom: -1px; left: 50%; transform: translateX(-50%);
    border-left: 5px solid transparent; border-right: 5px solid transparent; border-top: 6px solid var(--a1);
  }

  .dnote {
    align-self: flex-end; margin: -6px 0 -2px; font-family: var(--mono); font-size: 11.5px;
    color: var(--faint); background: var(--bg); border: 1px dashed var(--border-strong);
    border-radius: 8px; padding: 5px 10px;
  }
  .dnote b { color: var(--a1); font-weight: 600; }

  .subpipe {
    margin-top: 12px; display: flex; flex-wrap: wrap; align-items: center; gap: 6px;
    padding-top: 12px; border-top: 1px dashed var(--border-strong);
  }
  .subpipe .chip {
    font-family: var(--mono); font-size: 11.5px; padding: 4px 9px; border-radius: 7px;
    background: var(--bg); border: 1px solid var(--border-strong); color: var(--text-2);
  }
  .subpipe .chip.accent { background: var(--accent-soft); border-color: rgba(54,180,244,0.4); color: var(--a1); }
  .subpipe .sep { color: var(--faint); font-family: var(--mono); }

  .dstage.box5 { flex-direction: column; align-items: stretch; gap: 0; }
  .dstage.box5 .head { display: flex; align-items: center; gap: 14px; }

  /* ---------- code blocks ---------- */
  .code-island { margin: 22px 0; border: 1px solid var(--border-strong); border-radius: var(--radius); overflow: hidden; background: #06080d; }
  .ci-bar { display: flex; align-items: center; gap: 8px; padding: 11px 15px; background: #0c0f17; border-bottom: 1px solid var(--border); }
  .ci-bar .d { width: 11px; height: 11px; border-radius: 50%; }
  .ci-bar .d.r { background: #ff5f56; } .ci-bar .d.y { background: #ffbd2e; } .ci-bar .d.g { background: #27c93f; }
  .ci-name { font-family: var(--mono); font-size: 12px; color: var(--faint); margin-left: 8px; }
  pre { margin: 0; padding: 18px 20px; overflow-x: auto; font-family: var(--mono); font-size: 13.5px; line-height: 1.7; }
  pre code { font-family: inherit; white-space: pre; }
  .k { color: #c792ea; }    /* keyword */
  .d2 { color: var(--a1); } /* decorator */
  .s { color: #c3e88d; }    /* string */
  .t { color: var(--a1); }  /* type */
  .f { color: #82aaff; }    /* fn */
  .c { color: var(--faint); font-style: italic; } /* comment */

  /* ---------- tree ---------- */
  .tree {
    margin-top: 30px; background: #06080d; border: 1px solid var(--border-strong); border-radius: var(--radius);
    padding: 18px 22px; font-family: var(--mono); font-size: 13.5px;
  }
  .tree .row { display: flex; align-items: baseline; gap: 18px; padding: 2px 0; }
  .tree .branch { white-space: pre; flex: 0 0 auto; min-width: 230px; color: var(--text-2); }
  .tree .dir { color: var(--a1); }
  .tree .cmt { color: var(--faint); }
  @media (max-width: 680px) {
    .tree .row { flex-direction: column; gap: 0; padding: 6px 0; }
    .tree .branch { min-width: 0; }
    .tree .cmt { padding-left: 2.4ch; font-size: 12.5px; }
  }

  /* ---------- principles ---------- */
  .principle { display: flex; gap: 16px; padding: 20px 0; border-bottom: 1px solid var(--border); }
  .principle:last-child { border-bottom: none; }
  .principle .pn { font-family: var(--mono); color: var(--faint); font-size: 14px; flex: none; width: 30px; }
  .principle h3 { margin: 0 0 5px; font-size: 16.5px; font-family: var(--font-display); }
  .principle p { margin: 0; color: var(--text-2); font-size: 14.5px; }

  /* ---------- ref table ---------- */
  table { width: 100%; border-collapse: collapse; margin-top: 28px; font-size: 14px; }
  th, td { text-align: left; padding: 13px 16px; border-bottom: 1px solid var(--border); vertical-align: top; }
  th { font-family: var(--mono); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--faint); font-weight: 600; }
  td:first-child { font-family: var(--mono); color: var(--a1); white-space: nowrap; }
  td code { font-family: var(--mono); color: var(--a1); }
  tr:hover td { background: rgba(255,255,255,0.018); }

  /* ---------- callout ---------- */
  .callout {
    margin: 30px 0 0; padding: 18px 20px; border-radius: var(--radius);
    background: rgba(255, 203, 122, 0.06); border: 1px solid rgba(255, 203, 122, 0.25);
    display: flex; gap: 14px; align-items: flex-start;
  }
  .callout .ic { font-size: 20px; flex: none; }
  .callout p { margin: 0; color: var(--text-2); font-size: 14.5px; }
  .callout b { color: var(--amber); }
  .callout.blue { background: var(--accent-soft); border-color: rgba(54,180,244,0.28); }
  .callout.blue b { color: var(--a1); }

  /* ---------- footer ---------- */
  footer { padding: 50px 0 70px; border-top: 1px solid var(--border); color: var(--faint); font-size: 14px; }
  footer .wrap { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; justify-content: space-between; }
  .badge { display: inline-block; font-family: var(--mono); font-size: 11px; padding: 3px 9px; border-radius: 6px; background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--text-2); }
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="nav-inner">
    <a class="brand" href="/"><img src={logo.src} alt="" /> Nestgram <span class="sub">internals</span></a>
    <div class="nav-links">
      <a href="#why">Why</a>
      <a href="#map">Map</a>
      <a href="#pipeline">Pipeline</a>
      <a href="#dx">DX</a>
      <a href="#principles">Principles</a>
      <a href="#ref">Reference</a>
      <a class="ext" href={docsUrl}>Docs ↗</a>
    </div>
  </div>
</nav>

<!-- HERO -->
<header class="hero">
  <div class="wrap">
    <span class="eyebrow"><span class="dot-pulse"></span> internals · the engine, end to end</span>
    <h1>A Telegram bot is just <span class="grad">another NestJS app</span>.</h1>
    <p class="lead">
      This page documents how Nestgram works beneath the surface. Building on
      <strong>telegraf</strong>, <strong>grammY</strong>, <strong>aiogram</strong> and the bare
      <strong>node-telegram-bot-api</strong> kept surfacing the same problems — a god-context object,
      and a middleware system bolted on beside the framework you actually use. Nestgram takes the
      opposite stance: a Telegram bot should live <strong>inside Nest's own pipeline</strong>,
      unchanged. What follows is how that is wired internally.
    </p>
    <div class="signoff">
      <span class="avatar">📐</span>
      <span>Written for contributors and the curious — not required reading to ship a bot, but the full path of an update from Telegram to your handler and back.</span>
    </div>

    <div class="mental">
      <div class="mm-label">Mental model</div>
      <div class="mm-flow">
        <span class="mm-box">Telegram update</span>
        <span class="mm-arrow">→</span>
        <span class="mm-box mm-accent">@Router() controller</span>
        <span class="mm-arrow">→</span>
        <span class="mm-box">handler method</span>
        <span class="mm-arrow">→</span>
        <span class="mm-box">reply</span>
      </div>
    </div>
  </div>
</header>

<!-- WHY -->
<section id="why">
  <div class="wrap">
    <span class="sec-tag">Why another framework</span>
    <h2>The pain we saw — and how we answer it</h2>
    <p class="sec-intro">
      telegraf and grammY are excellent clients, and Nestgram borrows freely from them —
      first-match routing comes straight from aiogram. But each carries systemic friction that
      surfaces precisely on serious, high-load bots. Here is the honest comparison.
    </p>

    <div class="vs">
      <div class="vs-col pain">
        <h4>How it hurts elsewhere</h4>
        <ul>
          <li><b>God-context.</b> Everything hangs off a single <span class="inline-code">ctx</span> — data, actions, session, i18n. What actually arrived is a guessing game.</li>
          <li><b>A parallel middleware system.</b> Its own <span class="inline-code">.use()</span> chain, bolted on beside your app. Your Nest DI, guards and pipes don't apply inside it.</li>
          <li><b>Magic strings in callback_data.</b> <span class="inline-code">buy:</span> to build, <span class="inline-code">/^buy:(\d+)/</span> to match, <span class="inline-code">split(':')</span> to parse — three places that drift apart.</li>
          <li><b>Hand-written types.</b> 150+ Bot API types that grow every month, maintained by hand and always lagging.</li>
          <li><b>node-telegram-bot-api</b> — a bare EventEmitter: no structure, no DI, no testability.</li>
        </ul>
      </div>
      <div class="vs-col gain">
        <h4>How Nestgram does it</h4>
        <ul>
          <li><b>A typed positional event.</b> <span class="inline-code">handle(message: Message)</span> — you named the type, so you know what arrived. No god-context.</li>
          <li><b>The real Nest pipeline.</b> Guards → interceptors → pipes → handler → exception filters work <b>unchanged</b> — through Nest's <span class="inline-code">ExternalContextCreator</span>.</li>
          <li><b>Actions live on the event.</b> <span class="inline-code">message.answer(...)</span> sits on a command-object layer (<span class="inline-code">new SendMessage(...)</span>), fully testable.</li>
          <li><b>Router discovery.</b> Just list the class in <span class="inline-code">providers</span> — no registry to maintain by hand.</li>
          <li><b>No privileged core.</b> Auto-answering a callback is an ordinary interceptor — one you could have written yourself.</li>
        </ul>
      </div>
    </div>

    <div class="callout blue">
      <span class="ic">⚖️</span>
      <p><b>The one rule that overrides all others:</b> Developer Experience &gt; the purity of our own code. When they conflict, DX wins. We accept hard, reflection-heavy internals so the bot author's code stays minimal and declarative — the same bargain NestJS itself makes.</p>
    </div>
  </div>
</section>

<!-- MAP -->
<section id="map">
  <div class="wrap">
    <span class="sec-tag">Repository map</span>
    <h2>What lives where in <span class="inline-code">lib/</span></h2>
    <p class="sec-intro">
      Source lives in <span class="inline-code">lib/</span> (not <span class="inline-code">src/</span>), build output in <span class="inline-code">dist/</span>, files are kebab-case throughout.
      The structure mirrors the flow: <b>engine/</b> is the internal update→dispatch machinery; everything else
      is the public surface the bot author touches.
    </p>

    <div class="tree">
      <div class="row"><span class="branch"><span class="dir">lib/</span></span></div>
      <div class="row"><span class="branch">├─ <span class="dir">engine/</span></span><span class="cmt"># 🫀 the engine: the path from update to dispatch</span></div>
      <div class="row"><span class="branch">│  ├─ <span class="dir">source/</span></span><span class="cmt"># where updates come from (polling; webhook later)</span></div>
      <div class="row"><span class="branch">│  ├─ <span class="dir">context/</span></span><span class="cmt"># wraps the update + lazy rich event (no mutation)</span></div>
      <div class="row"><span class="branch">│  ├─ <span class="dir">discovery/</span></span><span class="cmt"># boot-time route table + matcher</span></div>
      <div class="row"><span class="branch">│  ├─ <span class="dir">matching/</span></span><span class="cmt"># route predicates (@Command/@Action/@Hears)</span></div>
      <div class="row"><span class="branch">│  ├─ <span class="dir">execution/</span></span><span class="cmt"># ECC wiring, params-factory, extractors, result</span></div>
      <div class="row"><span class="branch">│  └─ <span class="dir">dispatcher/</span></span><span class="cmt"># orchestrates a single update</span></div>
      <div class="row"><span class="branch">├─ <span class="dir">api/</span></span><span class="cmt"># Telegram transport: BotService + methods/ (command objects)</span></div>
      <div class="row"><span class="branch">├─ <span class="dir">events/</span></span><span class="cmt"># rich typed events: Message, CallbackQuery, User</span></div>
      <div class="row"><span class="branch">├─ <span class="dir">decorators/</span></span><span class="cmt"># public: @Router, listeners/, params/</span></div>
      <div class="row"><span class="branch">├─ <span class="dir">keyboards/</span></span><span class="cmt"># Inline/Reply/Remove keyboard builders</span></div>
      <div class="row"><span class="branch">├─ <span class="dir">interceptors/</span></span><span class="cmt"># built-ins as ordinary interceptors (auto-answer)</span></div>
      <div class="row"><span class="branch">├─ <span class="dir">module/</span></span><span class="cmt"># NestgramModule.forRoot + bootstrap</span></div>
      <div class="row"><span class="branch">├─ <span class="dir">exceptions/</span></span><span class="cmt"># ApiException</span></div>
      <div class="row"><span class="branch">├─ providers.ts</span><span class="cmt"># DI tokens (NESTGRAM_OPTIONS, …)</span></div>
      <div class="row"><span class="branch">└─ index.ts</span><span class="cmt"># public barrel</span></div>
    </div>

    <div class="grid cols-3">
      <div class="card">
        <h3><span class="ic">🫀</span> engine/</h3>
        <p>The heart of the framework. Six subfolders = six stages of one pipeline. After boot there is <b>zero reflection per update</b> — everything is resolved ahead of time.</p>
        <span class="path">lib/engine/</span>
      </div>
      <div class="card">
        <h3><span class="ic">📡</span> api/</h3>
        <p><span class="inline-code">BotService</span> is the HTTP transport. <span class="inline-code">methods/</span> holds command objects (<span class="inline-code">SendMessage</span>, <span class="inline-code">GetMe</span>…), each with a <span class="inline-code">.fetch()</span>.</p>
        <span class="path">lib/api/</span>
      </div>
      <div class="card">
        <h3><span class="ic">📦</span> events/</h3>
        <p>Rich classes carrying data <b>and</b> actions: <span class="inline-code">message.answer()</span>, <span class="inline-code">query.alert()</span>. Built via <span class="inline-code">Object.assign</span> onto a fresh instance — the raw update is never touched.</p>
        <span class="path">lib/events/</span>
      </div>
      <div class="card">
        <h3><span class="ic">🏷️</span> decorators/</h3>
        <p><span class="inline-code">@Router</span>, listeners (<span class="inline-code">@Command/@Action/@Hears</span> + ~26 <span class="inline-code">@On*</span>), params (<span class="inline-code">@Sender/@Args/@Payload…</span>).</p>
        <span class="path">lib/decorators/</span>
      </div>
      <div class="card">
        <h3><span class="ic">⌨️</span> keyboards/</h3>
        <p>Fluent builders: <span class="inline-code">.columns(2)</span>, <span class="inline-code">.row()</span>, a hidden flag for conditional buttons. <span class="inline-code">toJSON()</span> emits the Telegram shape.</p>
        <span class="path">lib/keyboards/</span>
      </div>
      <div class="card">
        <h3><span class="ic">🔌</span> module/</h3>
        <p><span class="inline-code">NestgramModule.forRoot/forRootAsync</span> + <span class="inline-code">NestgramBootstrap</span>: assembles the engine at boot, validates the token, stops polling on shutdown.</p>
        <span class="path">lib/module/</span>
      </div>
    </div>
  </div>
</section>

<!-- PIPELINE -->
<section id="pipeline">
  <div class="wrap">
    <span class="sec-tag">The core · step by step</span>
    <h2>The journey of a single update, end to end</h2>
    <p class="sec-intro">
      This is what everything is for. We trace the real flow through the code — from the moment
      Telegram hands over JSON to the moment the user sees a reply. Each step is a concrete folder
      under <span class="inline-code">engine/</span>.
    </p>

    <!-- FLOW DIAGRAM -->
    <div class="diagram">
      <div class="dstage edge"><span class="ic">📨</span> Telegram · raw update (JSON)</div>
      <div class="dconn"></div>

      <div class="dstage">
        <span class="dnum">1</span>
        <div class="dtxt"><b>Source</b><small>deleteWebhook → getMe → loop: fetch → advance offset → emit</small></div>
        <span class="dpath">engine/source</span>
      </div>
      <div class="dconn"></div>

      <div class="dstage">
        <span class="dnum">2</span>
        <div class="dtxt"><b>Dispatcher</b><small>one try/catch, never throws · per-update isolation</small></div>
        <span class="dpath">engine/dispatcher</span>
      </div>
      <div class="dconn"></div>

      <div class="dstage">
        <span class="dnum">3</span>
        <div class="dtxt"><b>Context · wrap</b><small>resolveKind → Readonly wrapper → lazy rich event</small></div>
        <span class="dpath">engine/context</span>
      </div>
      <div class="dconn"></div>

      <div class="dnote">⤷ <b>Route table</b> built once at boot</div>
      <div class="dstage">
        <span class="dnum">4</span>
        <div class="dtxt"><b>Matching</b><small>ofType(kind) → predicates → first match wins</small></div>
        <span class="dpath">engine/matching</span>
      </div>
      <div class="dconn"></div>

      <div class="dstage box5 hot">
        <div class="head">
          <span class="dnum">5</span>
          <div class="dtxt"><b>Execution · ExternalContextCreator</b><small>the full Nest pipeline around your handler</small></div>
          <span class="dpath">engine/execution</span>
        </div>
        <div class="subpipe">
          <span class="chip">Guards</span><span class="sep">→</span>
          <span class="chip">Interceptors</span><span class="sep">→</span>
          <span class="chip">Pipes</span><span class="sep">→</span>
          <span class="chip accent">Handler</span><span class="sep">→</span>
          <span class="chip">Exception filters</span>
        </div>
      </div>
      <div class="dconn"></div>

      <div class="dstage">
        <span class="dnum">6</span>
        <div class="dtxt"><b>Result</b><small>string → reply · command → .fetch() · void → noop</small></div>
        <span class="dpath">result-handler</span>
      </div>
      <div class="dconn"></div>

      <div class="dstage edge"><span class="ic">↩️</span> reply → Telegram</div>
    </div>

    <div class="steps">

      <!-- step 0 -->
      <div class="step">
        <div class="step-rail"><div class="step-n">0</div><div class="step-line"></div></div>
        <div class="step-body">
          <h3>Boot: the route table is built <em>once</em> <span class="where">module/nestgram.bootstrap.ts</span></h3>
          <p>
            On <span class="inline-code">OnApplicationBootstrap</span> (when every provider already exists) <span class="inline-code">NestgramBootstrap</span> validates the token,
            warns about a webhook without a secret token, and calls <span class="inline-code">routeTable.set(routeExplorer.explore())</span>.
            <b>This is the only place we do reflection.</b> After that, it's pure lookup.
          </p>
          <p>
            <span class="inline-code">RouteExplorer</span> (in <span class="inline-code">engine/discovery/</span>) walks every provider through Nest's
            <span class="inline-code">DiscoveryService</span> + <span class="inline-code">MetadataScanner</span>, finds classes carrying <span class="inline-code">@Router</span> metadata,
            reads <span class="inline-code">@Command/@On*</span> off each method, and collects a flat <span class="inline-code">Route[]</span> in declaration order.
          </p>
          <div class="step-key"><b>Why at boot, not per update:</b> reflection is expensive. Pay it once — get a type-indexed table for the entire runtime.</div>
        </div>
      </div>

      <!-- step 1 -->
      <div class="step">
        <div class="step-rail"><div class="step-n">1</div><div class="step-line"></div></div>
        <div class="step-body">
          <h3>Source: where updates come from <span class="where">engine/source/</span></h3>
          <p>
            <span class="inline-code">PollingUpdateSource</span> prepares the transport on start: <span class="inline-code">deleteWebhook</span> (so polling is allowed) →
            <span class="inline-code">getMe</span> (a health check that fails fast on a bad token). Then it loops: fetch a batch via
            <span class="inline-code">getUpdates(offset)</span> → <b>advance the offset</b> (acknowledge receipt) → emit each update to the dispatcher.
          </p>
          <p>
            A failed <span class="inline-code">getUpdates</span> backs off and continues rather than killing the loop. An empty batch idles via a timer
            (so microtasks can't starve I/O). The transport is decoupled from the dispatcher — the webhook source (Phase 2) plugs in right here, with zero handler changes.
          </p>
          <div class="step-key"><b>Delivery semantics:</b> the offset advances after a batch is received → at-most-once for polling (a crash drops in-flight updates). A deliberate, documented trade-off.</div>
        </div>
      </div>

      <!-- step 2 -->
      <div class="step">
        <div class="step-rail"><div class="step-n">2</div><div class="step-line"></div></div>
        <div class="step-body">
          <h3>Dispatcher: orchestrating one update <span class="where">engine/dispatcher/</span></h3>
          <p>
            <span class="inline-code">UpdateDispatcher.dispatch(update)</span> runs the whole thing end to end inside a single <span class="inline-code">try/catch</span> that
            <b>never throws</b>. That's per-update isolation: one bad update is logged and never takes down polling (the source awaits this call in its loop).
          </p>
          <div class="code-island">
            <div class="ci-bar"><span class="d r"></span><span class="d y"></span><span class="d g"></span><span class="ci-name">update-dispatcher.ts</span></div>
            <pre><code set:html={dispatcherCode}></code></pre>
          </div>
          <div class="step-key"><b>Invokers are cached</b> in a <span class="inline-code">WeakMap&lt;Route&gt;</span>: ECC <span class="inline-code">create()</span> isn't cheap, so we build it once per route — steady state is just matching + the cached call.</div>
        </div>
      </div>

      <!-- step 3 -->
      <div class="step">
        <div class="step-rail"><div class="step-n">3</div><div class="step-line"></div></div>
        <div class="step-body">
          <h3>Context: wrap, don't mutate <span class="where">engine/context/</span></h3>
          <p>
            <span class="inline-code">ContextFactory.wrap</span> calls <span class="inline-code">resolveKind</span> (a closed <span class="inline-code">UpdateKind</span> whitelist — unknown fields are ignored, not guessed)
            and builds a <span class="inline-code">TelegramExecutionContext</span>. The raw update sits as <span class="inline-code">Readonly&lt;RawUpdate&gt;</span> and is <b>never rewritten</b>.
          </p>
          <p>
            The rich event (<span class="inline-code">Message</span>, <span class="inline-code">CallbackQuery</span>) is built <b>lazily and cached</b> on first access — via
            <span class="inline-code">EventFactory</span>, which looks the kind up in the <span class="inline-code">@UpdateType</span> registry. Adding a new event type means decorating a class, not editing a switch.
          </p>
          <div class="step-key"><b>Contrast with god-context:</b> there is no <span class="inline-code">update._type = …</span> mutation here. The context is a wrapper that guards, param decorators and matchers read via <span class="inline-code">TelegramExecutionContext.of(ctx)</span>.</div>
        </div>
      </div>

      <!-- step 4 -->
      <div class="step">
        <div class="step-rail"><div class="step-n">4</div><div class="step-line"></div></div>
        <div class="step-body">
          <h3>Matching: which handler fires <span class="where">engine/discovery/ + engine/matching/</span></h3>
          <p>
            <span class="inline-code">RouteMatcher.findMatches</span> only walks candidates of the right kind (<span class="inline-code">table.ofType(kind)</span> — pre-indexed),
            running each <span class="inline-code">RoutePredicate.matches(ctx)</span> in turn. The first match in declaration order wins (first-match, as in aiogram).
          </p>
          <p>
            Predicates are <span class="inline-code">CommandPredicate</span> / <span class="inline-code">ActionPredicate</span> / <span class="inline-code">HearsPredicate</span>. Note the name:
            <b>predicate</b>, not "filter" — in Nest a "filter" is an exception filter. Route matching is deliberately kept distinct from error handling.
          </p>
          <div class="step-key"><b>Ordering:</b> within one router, method declaration order. Across routers, discovery order — don't rely on it.</div>
        </div>
      </div>

      <!-- step 5 -->
      <div class="step">
        <div class="step-rail"><div class="step-n">5</div><div class="step-line"></div></div>
        <div class="step-body">
          <h3>Execution: the full Nest pipeline around your handler <span class="where">engine/execution/</span></h3>
          <p>
            This is where "update = request" becomes real. <span class="inline-code">HandlerExecutorFactory</span> uses Nest's <span class="inline-code">ExternalContextCreator</span> to build an invoker that
            runs <b>guards → interceptors → pipes → handler → exception filters</b> — exactly like an HTTP route. The invoker is called as <span class="inline-code">invoker(event, ctx)</span>.
          </p>
          <div class="code-island">
            <div class="ci-bar"><span class="d r"></span><span class="d y"></span><span class="d g"></span><span class="ci-name">handler-executor.factory.ts</span></div>
            <pre><code set:html={executorCode}></code></pre>
          </div>
          <div class="step-key"><b>Hard-won lesson (ECC-NOTES):</b> ECC resolves params all-or-nothing. So <em>every</em> param must be a decorator — and the framework auto-applies <span class="inline-code">@Event()</span> to param 0, so you can write <span class="inline-code">handle(message: Message)</span> with <b>no</b> decorator.</div>
        </div>
      </div>

      <!-- step 6 -->
      <div class="step">
        <div class="step-rail"><div class="step-n">6</div><div class="step-line"></div></div>
        <div class="step-body">
          <h3>Result: whatever the handler returns is what we do <span class="where">engine/execution/result-handler.ts</span></h3>
          <p>
            The return contract is simple and predictable:
          </p>
          <div class="code-island">
            <div class="ci-bar"><span class="d r"></span><span class="d y"></span><span class="d g"></span><span class="ci-name">result-handler.ts</span></div>
            <pre><code set:html={resultCode}></code></pre>
          </div>
          <p>
            <span class="inline-code">return message.answer(...)</span> returns an already-sent result — a noop for us, not an error. A command object is detected by duck-typing on <span class="inline-code">.fetch()</span>.
          </p>
          <div class="step-key"><b>And finally</b> — the global <span class="inline-code">AutoAnswerCallbackInterceptor</span> (step 5, an interceptor!) quietly answers a callback the handler left unanswered, so the button never spins.</div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- DX LAYER -->
<section id="dx">
  <div class="wrap">
    <span class="sec-tag">DX layer</span>
    <h2>What it looks like for the bot author</h2>
    <p class="sec-intro">
      All the complexity above exists for one thing: so your code stays short and declarative.
      If you've written a Nest HTTP controller, you already know the shape.
    </p>

    <div class="code-island">
      <div class="ci-bar"><span class="d r"></span><span class="d y"></span><span class="d g"></span><span class="ci-name">greet.router.ts</span></div>
      <pre><code set:html={greetCode}></code></pre>
    </div>

    <div class="grid cols-3">
      <div class="card">
        <h3><span class="ic">🎯</span> Listeners</h3>
        <p><span class="inline-code">@Command('start')</span> matches <span class="inline-code">/start</span>, <span class="inline-code">/start args</span>, <span class="inline-code">/start@Bot</span>. Plus <span class="inline-code">@Action</span> (callback), <span class="inline-code">@Hears</span> (text) and ~26 <span class="inline-code">@On*</span> for every update type.</p>
        <span class="path">decorators/listeners/</span>
      </div>
      <div class="card">
        <h3><span class="ic">💉</span> Param decorators</h3>
        <p>For <em>derived</em> values, not the main event: <span class="inline-code">@Sender()</span>, <span class="inline-code">@Chat()</span>, <span class="inline-code">@Args()</span>, <span class="inline-code">@Payload()</span>, <span class="inline-code">@CallbackData()</span>, <span class="inline-code">@State()</span>.</p>
        <span class="path">decorators/params/</span>
      </div>
      <div class="card">
        <h3><span class="ic">⌨️</span> Keyboards</h3>
        <p><span class="inline-code">new InlineKeyboard().columns(2).text('Buy','buy')</span>. A hidden flag for conditional buttons: <span class="inline-code">.text('Admin','adm', !isAdmin)</span>.</p>
        <span class="path">keyboards/</span>
      </div>
      <div class="card">
        <h3><span class="ic">📦</span> Actions on events</h3>
        <p><span class="inline-code">message.answer/reply/editText</span>, <span class="inline-code">query.answer/alert</span>. Sugar over command objects — the power-user path <span class="inline-code">return new SendMessage(...)</span> is always open and testable without mocks.</p>
        <span class="path">events/ · api/methods/</span>
      </div>
      <div class="card">
        <h3><span class="ic">🛡️</span> Guards / Pipes / Filters</h3>
        <p>Plain Nest primitives. <span class="inline-code">@UseGuards(AdminGuard)</span> on a router or method <b>just works</b>, because the handler runs through ECC.</p>
        <span class="path">via ExternalContextCreator</span>
      </div>
      <div class="card">
        <h3><span class="ic">🔧</span> Config</h3>
        <p><span class="inline-code">forRoot(&#123; token, polling &#125;)</span> or <span class="inline-code">forRootAsync(&#123; useFactory, inject &#125;)</span> with <span class="inline-code">ConfigModule</span>. Defaults (<span class="inline-code">parseMode</span>, auto-answer) are all opt-out.</p>
        <span class="path">module/</span>
      </div>
    </div>
  </div>
</section>

<!-- PRINCIPLES -->
<section id="principles">
  <div class="wrap">
    <span class="sec-tag">Locked decisions</span>
    <h2>Principles we don't revisit without good reason</h2>

    <div class="principle">
      <span class="pn">01</span>
      <div><h3>DX &gt; the purity of our own code</h3><p>When they conflict, developer experience wins. Hard internals in exchange for sterile author code. Non-negotiable.</p></div>
    </div>
    <div class="principle">
      <span class="pn">02</span>
      <div><h3>Our own discovery engine, not a wrapper</h3><p><span class="inline-code">DiscoveryService</span> + <span class="inline-code">MetadataScanner</span>, a boot-time route table. Not a microservice transport, not a wrapper over telegraf/grammY.</p></div>
    </div>
    <div class="principle">
      <span class="pn">03</span>
      <div><h3>The Nest pipeline around the handler</h3><p>Via <span class="inline-code">ExternalContextCreator</span>, so guards/interceptors/pipes/filters work. No parallel middleware system.</p></div>
    </div>
    <div class="principle">
      <span class="pn">04</span>
      <div><h3>The main argument is the typed event, positional</h3><p><span class="inline-code">handle(message: Message)</span>. Param decorators are only for cross-cutting / derived values. No god-context.</p></div>
    </div>
    <div class="principle">
      <span class="pn">05</span>
      <div><h3>No privileged core</h3><p>Everything the framework does is built on the same public extension points it hands you. Auto-answer is just an interceptor.</p></div>
    </div>
    <div class="principle">
      <span class="pn">06</span>
      <div><h3>Types from code generation (Phase 2)</h3><p>From a community spec (<span class="inline-code">ark0f/tg-bot-api</span>) — both types and method classes. Hand-written for now; an API update becomes a generator run, not manual labour.</p></div>
    </div>
  </div>
</section>

<!-- REFERENCE -->
<section id="ref">
  <div class="wrap">
    <span class="sec-tag">Reference</span>
    <h2>"I need to change X — where do I go"</h2>
