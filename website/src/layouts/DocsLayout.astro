---
// Nestgram docs shell. Renders the mockup three-column layout:
// top nav · sidebar · content · right TOC. Sidebar groups come from the
// docs collection (per-file frontmatter); the TOC comes from Astro's
// generated `headings`. Scroll-spy is the only JS on the page.
import '../styles/docs.css';
import logo from '../assets/nestgram.svg';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface NavItem {
  label: string;
  href: string;
}
interface NavGroup {
  label: string;
  items: NavItem[];
}
interface PagerLink {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumb?: string;
  headings?: Heading[];
  sidebar?: NavGroup[];
  current?: string;
  prev?: PagerLink | null;
  next?: PagerLink | null;
}

const {
  title,
  description = '',
  breadcrumb = 'Docs',
  headings = [],
  sidebar = [],
  current = '',
  prev = null,
  next = null,
} = Astro.props;

// Only h2/h3 belong in the "On this page" rail.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const githubUrl = 'https://github.com/Degreet/nestgram-v2';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Nestgram</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <header class="dx-nav">
      <a class="dx-brand" href="/"><img src={logo.src} alt="" />Nestgram</a>
      <nav class="dx-nav-right">
        <a href="/docs/quickstart">Docs</a>
        <a href={githubUrl}>GitHub</a>
      </nav>
    </header>

    <div class="dx-shell">
      <aside class="dx-sidebar">
        {
          sidebar.map((group) => (
            <div class="dx-group">
              <p class="dx-group-label">{group.label}</p>
              <ul>
                {group.items.map((it) => (
                  <li>
                    <a href={it.href} class={it.href === current ? 'active' : ''}>
                      {it.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </aside>

      <main class="dx-main">
        <div class="dx-breadcrumb">{breadcrumb}</div>
        <article class="dx-content">
          <h1>{title}</h1>
          <slot />

          {
            (prev || next) && (
              <nav class="dx-pager">
                {prev ? (
                  <a class="dx-pager-btn dx-pager-prev" href={prev.href}>
                    <span class="dx-pager-dir">← Previous</span>
                    <span class="dx-pager-title">{prev.label}</span>
                  </a>
                ) : (
                  <span class="dx-pager-spacer" />
                )}
                {next ? (
                  <a class="dx-pager-btn dx-pager-next" href={next.href}>
                    <span class="dx-pager-dir">Next →</span>
                    <span class="dx-pager-title">{next.label}</span>
                  </a>
                ) : (
                  <span class="dx-pager-spacer" />
                )}
              </nav>
            )
          }
        </article>
      </main>

      <nav class="dx-toc">
        {
          toc.length > 0 && (
            <>
              <p class="dx-toc-label">On this page</p>
              <ul>
                {toc.map((t) => (
                  <li>
                    <a href={`#${t.slug}`} class={`lvl-${t.depth}`} data-toc={t.slug}>
                      {t.text}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          )
        }
      </nav>
    </div>

    <script>
      // scroll-spy: highlight the current section in the right TOC.
      const links = [...document.querySelectorAll<HTMLAnchorElement>('.dx-toc a[data-toc]')];
      const map = new Map(links.map((a) => [a.getAttribute('data-toc'), a]));
      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              links.forEach((a) => a.classList.remove('active'));
              map.get(e.target.id)?.classList.add('active');
            }
          }
        },
        { rootMargin: '0px 0px -75% 0px', threshold: 0 },
      );
      document
        .querySelectorAll('.dx-content h2[id], .dx-content h3[id]')
        .forEach((h) => obs.observe(h));

      // Copy-to-clipboard for every code block. Code-island figures are
      // position:relative via CSS; bare Shiki <pre> blocks get wrapped in a
      // positioned shell so the button can sit top-right. Code blocks only.
      const COPY_ICON =
        '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2"></rect><path d="M5 15V5a2 2 0 0 1 2-2h10"></path></svg>';
      const DONE_ICON =
        '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>';
      const COPIED_MS = 1600;

      document.querySelectorAll<HTMLPreElement>('.dx-content pre').forEach((pre) => {
        const code = pre.querySelector('code') ?? pre;
        let host = pre.closest('.code-island') as HTMLElement | null;
        if (!host) {
          const wrap = document.createElement('div');
          wrap.className = 'code-island is-plain';
          pre.replaceWith(wrap);
          wrap.appendChild(pre);
          host = wrap;
        }
        if (host.querySelector('.code-copy')) return;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'code-copy';
        btn.setAttribute('aria-label', 'Copy code');
        btn.innerHTML =
          '<span class="code-copy__ico code-copy__ico--copy">' + COPY_ICON + '</span>' +
          '<span class="code-copy__ico code-copy__ico--done">' + DONE_ICON + '</span>' +
          '<span class="code-copy__txt">Copy</span>';
        btn.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(code.textContent ?? '');
            btn.classList.add('is-copied');
            const txt = btn.querySelector('.code-copy__txt');
            if (txt) txt.textContent = 'Copied';
            window.setTimeout(() => {
              btn.classList.remove('is-copied');
              if (txt) txt.textContent = 'Copy';
            }, COPIED_MS);
          } catch {
            /* clipboard blocked (insecure context) — fail silently */
          }
        });
        host.appendChild(btn);
      });
    </script>
  </body>
</html>
