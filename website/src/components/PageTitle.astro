---
// Overrides Starlight's PageTitle to add a breadcrumb trail above the
// page heading, matching the design mockup ("Getting started / Quickstart").
// Defensive: if the sidebar shape changes, it silently shows just the title.
const { entry, sidebar } = Astro.locals.starlightRoute;

/** Find the label of the sidebar group that contains the current page. */
function currentGroupLabel(entries) {
  for (const item of entries ?? []) {
    if (item.type === 'group') {
      const hit = (item.entries ?? []).some(
        (child) => child.type === 'link' && child.isCurrent,
      );
      if (hit) return item.label;
      const nested = currentGroupLabel(item.entries);
      if (nested) return nested;
    }
  }
  return undefined;
}

const group = currentGroupLabel(sidebar);
---

<div class="ng-breadcrumbs not-content" aria-hidden="true">
  {group && <span>{group}</span>}
  {group && <span class="sep">/</span>}
  <span class="cur">{entry.data.title}</span>
</div>
<h1 id="_top">{entry.data.title}</h1>

<style>
  .ng-breadcrumbs {
    font-family: var(--font-mono, monospace);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--muted, #7c889b);
    margin-bottom: 0.9rem;
    display: flex;
    gap: 0.55rem;
    align-items: center;
  }
  .ng-breadcrumbs .sep {
    color: var(--accent, #1f8fe6);
  }
  .ng-breadcrumbs .cur {
    color: var(--text-2, #b7c0cf);
  }
</style>
