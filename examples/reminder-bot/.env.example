# --- Telegram -----------------------------------------------------------------
# Token from @BotFather.
BOT_TOKEN=123456:your-bot-token-here

# Comma-separated Telegram user IDs allowed to use admin commands (/stats, /broadcast).
ADMIN_IDS=11111111,22222222

# Transport: long polling (default, great for local dev) or webhook (production).
# For webhook, set USE_WEBHOOK=true and a public HTTPS URL Telegram can reach.
USE_WEBHOOK=false
WEBHOOK_URL=https://your-domain.example/telegram/webhook
WEBHOOK_SECRET=a-long-random-string
PORT=3000

# --- Postgres (matches docker-compose) ----------------------------------------
DATABASE_URL=postgres://nestgram:nestgram@localhost:5432/reminders

# --- Redis (BullMQ, matches docker-compose) -----------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
