{
  "name": "nestgram",
  "version": "2.0.0-alpha.0",
  "description": "Telegram bots, the NestJS way — typed events, the real Nest pipeline (guards, interceptors, pipes, filters), and a generated Bot API layer",
  "author": "Mykyta Voitsekhovskyi <mykyta@kodo.do>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://nestgram.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Degreet/nestgram.git"
  },
  "bugs": {
    "url": "https://github.com/Degreet/nestgram/issues"
  },
  "keywords": [
    "nodejs",
    "nest",
    "nestjs",
    "telegram",
    "telegram-bot",
    "telegram-bot-api",
    "bot",
    "bot-framework",
    "fsm",
    "typescript",
    "javascript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "tag": "next"
  },
  "workspaces": [
    "examples/reminder-bot"
  ],
  "scripts": {
    "build": "nest build",
    "start:dev": "nodemon lib/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"lib/**/*.ts\" --max-warnings 0",
    "format": "prettier --write \"lib/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate": "ts-node --project tools/codegen/tsconfig.json tools/codegen/index.ts",
    "spec:update": "ts-node --project tools/codegen/tsconfig.json tools/codegen/spec-update.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run build && npm run test && npm run generate -- --check"
  },
  "devDependencies": {
    "@fluent/bundle": "^0.19.1",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/prettier": "^2.7.3",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^17.0.7",
    "prettier": "^2.8.8",
    "reflect-metadata": "^0.1.13",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@fluent/bundle": "^0.18.0 || ^0.19.0",
    "@nestjs/common": "^10.4.1 || ^11.0.0",
    "@nestjs/core": "^10.4.1 || ^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.1",
    "yaml": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@fluent/bundle": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "class-validator": {
      "optional": true
    },
    "yaml": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "prettier --write",
    "lib/**/*.ts": "eslint --fix"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "lib",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
