{
  "name": "nestgram",
  "version": "2.0.0-alpha.0",
  "description": "Telegram Bot Framework on Nest.js",
  "author": "Mykyta Voitsekhovskyi <mykyta@kodo.do>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://degreetpro.gitbook.io/nestgram/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Degreet/nestgram.git"
  },
  "keywords": [
    "nodejs",
    "nest",
    "nestjs",
    "telegram",
    "bot",
    "typescript",
    "javascript"
  ],
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start:dev": "nodemon lib/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"lib/**/*.ts\"",
    "format": "prettier --write \"lib/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^17.0.7",
    "prettier": "^2.8.8",
    "reflect-metadata": "^0.1.13",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typescript": "^5.1.3"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "prettier --write",
    "lib/**/*.ts": "eslint --fix"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "lib",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node"
  }
}
